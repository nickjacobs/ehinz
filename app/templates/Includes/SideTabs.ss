<div class="side-tabs">
	<% if $Files %>
		<a href="#downloads" class="tab">
			<img class="bullet-arrow-hash" src="images/icon-download-tab.png" />
			Downloads
		</a>
	<% end_if %>
	<% if $Links %>
		<a href="#links" class="tab">
			<img class="bullet-arrow-hash" src="images/icon-links-tab.png" />
			Useful links
		</a>
	<% end_if %>
</div>