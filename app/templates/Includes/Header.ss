<header class="page-top-header">
  <div class="container">
  	<div class="row">
  		<div class="col-6"><a class="home-link" href="/"><h1 class="sr-only">$Siteconfig.Title | $Siteconfig.Tagline</h1></a></div> 
  		<div class="col-6 text-right">
  			<% if $SearchForm %>				
				<div class="search-bar">
					$SearchForm
				</div>
			<% end_if %>
  		</div> 		
  	</div>
  </div>
</header>